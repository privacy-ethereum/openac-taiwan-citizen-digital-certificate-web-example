# Base URLs the browser uses to reach the three external services.

# go-zkid-verifier base URL (challenge + link-verify).
VITE_VERIFIER_BASE_URL=http://localhost:8080

# HiPKI LocalSignServer base URL. The browser opens
# `<VITE_HIPKI_BASE_URL>/popupForm` in a popup that bridges to the local
# API via postMessage (see `src/hipki-popup.ts`). The popup is
# same-origin with the LocalSignServer so its fetches do not need CORS
# headers. Same code path in dev and prod, no reverse proxy required.
VITE_HIPKI_BASE_URL=http://localhost:61161

# moica-revocation-smt base URL. In dev `vite.config.ts` proxies
# `/smt/*` -> http://localhost:3000 to dodge missing CORS headers.
VITE_SMT_BASE_URL=/smt

# Default issuer identifier for SMT proof lookups. `g2` = MOICA RSA-2048
# CA, `g3` = RSA-4096 CA.
VITE_SMT_ISSUER=g2

# Optional: override the upstream targets the dev proxy forwards to.
# VITE_SMT_PROXY_TARGET=http://localhost:3000

# Per-request fetch timeouts (milliseconds). A hung server aborts cleanly
# instead of leaving the proving UI spinning forever.
# VITE_VERIFIER_TIMEOUT_MS=15000
# VITE_SMT_TIMEOUT_MS=10000
